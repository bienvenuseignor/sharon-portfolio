{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A contact form message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A training registration",
      "type": "object",
      "properties": {
        "trainingId": { "type": "string" },
        "trainingTitle": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trainingId", "trainingTitle", "name", "email", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Contact messages"
    },
    "/registrations/{registrationId}": {
      "schema": { "$ref": "#/entities/Registration" },
      "description": "Training registrations"
    }
  }
}
